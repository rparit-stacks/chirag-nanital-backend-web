APP_NAME="Hyperlocal Multivendor"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://nainistore.in
APP_VERSION=1.0.0

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nainistore
DB_USERNAME=naini_user
DB_PASSWORD=

# Use file until migrations ran — database driver needs `sessions` table (empty DB → 500 on /install).
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# sync avoids `jobs` table before migrate; switch to database after install if needed
QUEUE_CONNECTION=sync

# file avoids `cache` table before migrate
CACHE_STORE=file

# Infinitie / HyperMart license (installer may write these)
LICENSE_PURCHASE_CODE=
LICENSE_TOKEN=
LICENSE_SIGNATURE=

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=nainistore.in,www.nainistore.in
