            "target": "packages"
        },
        {
            "type": "add",
            "source": "resources",
            "target": "resources"
        },
        {
            "type": "add",
            "source": "routes",
            "target": "routes"
        },
        {
            "type": "add",
            "source": "public/installer",
            "target": "public/installer"
        },
        {
            "type": "add",
            "source": "public/assets/admin",
            "target": "public/assets/admin"
